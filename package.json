{
  "name": "tape-plasmo",
  "displayName": "Tape",
  "version": "0.0.1",
  "description": "Record and replay browser actions. Macro recorder for the browser.",
  "author": "Vlad Kovaliov <v.v.kovaliov@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "single-active-browser-tab": "^1.9.0",
    "wi-command-stack": "^2.2.0",
    "wi-condition-builder": "^1.7.0",
    "wi-console-logger": "^1.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@plasmohq/storage": "^1.10.0",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "plasmo": "0.90.5",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "action": {
      "default_popup": "popup.html"
    },
    "permissions": [
      "storage",
      "activeTab"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
