{
  "name": "tape",
  "displayName": "Tape",
  "version": "1.0.0",
  "description": "Record and replay browser actions. Macro recorder for the browser.",
  "author": "Vlad Kovaliov <v.v.kovaliov@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "single-active-browser-tab": "^1.9.0",
    "wi-command-stack": "^2.2.0",
    "wi-condition-builder": "^1.7.0",
    "wi-console-logger": "^1.4.1"
  },
  "engines": {
    "node": "24",
    "npm": "11"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@plasmohq/storage": "^1.10.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "plasmo": "0.90.5",
    "prettier": "3.2.4",
    "semantic-release": "^25.0.3",
    "typescript": "5.3.3"
  },
  "manifest": {
    "action": {
      "default_popup": "popup.html"
    },
    "permissions": [
      "storage",
      "activeTab"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
